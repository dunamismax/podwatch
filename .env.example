DJANGO_SETTINGS_MODULE=podwatch.settings
DJANGO_SECRET_KEY=replace-this-before-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_DATABASE_PATH=db.sqlite3
DJANGO_TIME_ZONE=UTC

# Production example:
# DJANGO_SETTINGS_MODULE=podwatch.settings_production
# DJANGO_ALLOWED_HOSTS=podwatch.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://podwatch.example.com
