{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**/*.{ts,tsx,js,jsx,json}",
      "packages/**/*.{ts,tsx,js,jsx,json}",
      ".github/**/*.{yml,yaml}",
      "*.json",
      "*.yaml",
      "*.yml",
      "*.ts",
      "!apps/**/src/routeTree.gen.ts",
      "!legacy"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
