{
  "name": "podwatch",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @podwatch/api --filter @podwatch/web dev",
    "build": "pnpm -r --if-present build",
    "preview": "pnpm --filter @podwatch/web preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @podwatch/web test:e2e",
    "check": "biome check . && pnpm run typecheck && pnpm run test",
    "db:generate": "pnpm --filter @podwatch/api db:generate",
    "db:migrate": "pnpm --filter @podwatch/api db:migrate",
    "db:push": "pnpm --filter @podwatch/api db:push",
    "db:studio": "pnpm --filter @podwatch/api db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "typescript": "^5.9.3"
  }
}
