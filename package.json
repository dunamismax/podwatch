{
  "name": "podwatch",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "preview": "bun run --cwd apps/web preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "test": "bun run --workspaces --if-present test",
    "check": "biome check . && bun run --workspaces --if-present typecheck && bun run --workspaces --if-present test",
    "db:generate": "bun run --cwd packages/db generate",
    "db:push": "bun run --cwd packages/db push",
    "db:studio": "bun run --cwd packages/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5"
  }
}
